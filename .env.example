# Open Prospecting — copy to .env.local and fill in.

# Postgres (Neon works well and has a free tier).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Research + script writing.
ANTHROPIC_API_KEY=

# Lead discovery (serper | brave | none).
SEARCH_PROVIDER=none
SEARCH_API_KEY=
DISCOVERY_GEOGRAPHY=United States
# Comma-separated city seeds for local search, e.g. Toronto,Vancouver,Calgary.
DISCOVERY_CITIES=
DISCOVERY_DAILY_CAP=50

# Protects the discovery + pipeline endpoints. Generate with: openssl rand -hex 24
CRON_SECRET=
