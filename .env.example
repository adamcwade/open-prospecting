# Modus Outreach — internal prospecting tool (runs locally on port 3100)

# Use a SEPARATE database from the client-facing app (or the same Neon project,
# different database). This app owns the prospecting tables only.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

ANTHROPIC_API_KEY=

# OpenAI Realtime + STT for voice calls
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_STT_MODEL=gpt-4o-transcribe

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_OUTBOUND_POOL=

# Lead discovery (serper | brave | none)
SEARCH_PROVIDER=none
SEARCH_API_KEY=
DISCOVERY_GEOGRAPHY=United States
DISCOVERY_DAILY_CAP=50

# Voice media stream server
VOICE_STREAM_URL=
PUBLIC_URL=http://localhost:3100
VOICE_WS_PORT=8080

# Where agreed prospects are sent to sign up (fallback if onboarding handoff fails)
SIGNUP_URL=http://localhost:3000/signup

# Server-to-server onboarding handoff to the customer app.
# APP_ONBOARD_URL = customer app's /api/onboard; ONBOARD_SECRET must match the customer app.
APP_ONBOARD_URL=http://localhost:3000/api/onboard
ONBOARD_SECRET=

APP_BASE_URL=http://localhost:3100
CRON_SECRET=
